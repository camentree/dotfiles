# Nix store paths (oh-my-zsh, etc.)
[[ -f ~/.nix-paths.sh ]] && source ~/.nix-paths.sh

# Oh-my-zsh
ZSH_THEME=""
plugins=(history)
source $ZSH/oh-my-zsh.sh

# Starship prompt
eval "$(starship init zsh)"

# Aliases
alias pyc="rm **/*.pyc; rm -rf **/__pycache__"
alias cov-clean="rm .coverage.*"
alias git-open="open \`git config --get remote.origin.url\`"
alias vim="nvim"
alias vd="deactivate"
alias g="git"
alias gaa="git add --all"
alias gcm="git commit -m"
alias gco="git checkout"

# Functions
function _is-repo () { git rev-parse --git-dir &>/dev/null; }
function _is-branch () { git show-ref --verify --quiet "refs/heads/$1"; }
function _is-session () { tmux has-session -t "$1" &>/dev/null; }

function loadenv () { set -o allexport; source "${1:-.}/.env"; set +o allexport ; }
function git-clean () { git branch | grep -v "master\|main\|*" | xargs git branch -D ; }
function ls-ports () { lsof -PiTCP -sTCP:LISTEN ; }
function touch2 () { mkdir -p "$(dirname "$1")" && touch "$1" ; }

function nix-rebuild () { sudo $(which darwin-rebuild) switch --flake "$HOME/Projects/dotfiles#${1:?Usage: nix-rebuild <machine-name>}" ; }
function nix-current () { readlink /run/current-system ; }
function nix-ls () { darwin-rebuild --list-generations ; }

# wk: worktrees as hidden sibling directory with .env / CLAUDE.local.md auto-symlinked.
# Worktrees live at <repo-parent>/.<repo-name>-worktrees/<branch-slug>/.
function _wk-repo-root () { git rev-parse --path-format=absolute --git-common-dir 2>/dev/null | sed 's/\/\.git$//'; }
function _wk-slug () { echo "$1" | sed 's|/|-|g'; }
function _wk-path () {
  local root=$(_wk-repo-root) || return 1
  local parent=$(dirname "$root")
  local name=$(basename "$root")
  echo "$parent/.${name}-worktrees/$(_wk-slug "$1")"
}
function _wk-link () {
  local source="$1" target="$2"
  [ -e "$source" ] && [ ! -e "$target" ] && ln -s "$source" "$target"
}
function wk () {
  local create_new_branch=false
  if [[ "$1" == "-b" ]]; then create_new_branch=true; shift; fi
  local branch="$1"
  [ -z "$branch" ] && { echo "Usage: wk [-b] <branch>"; return 1; }
  _is-repo || { echo "Not in a git repo"; return 1; }

  local root=$(_wk-repo-root)
  local path=$(_wk-path "$branch")

  if [ -d "$path" ]; then
    cd "$path"
    return 0
  fi

  if $create_new_branch; then
    git worktree add -b "$branch" "$path" >&2 || return 1
  elif _is-branch "$branch"; then
    git worktree add "$path" "$branch" >&2 || return 1
  else
    echo "Branch '$branch' doesn't exist. Use 'wk -b $branch' to create."; return 1
  fi

  _wk-link "$root/.env" "$path/.env"
  _wk-link "$root/loquat/CLAUDE.local.md" "$path/loquat/CLAUDE.local.md"
  cd "$path"
}
function wkls () { git worktree list 2>/dev/null || echo "Not in a git repo"; }
function wkrm () {
  local branch="${1:-$(git rev-parse --abbrev-ref HEAD 2>/dev/null)}"
  [ -z "$branch" ] && { echo "Usage: wkrm [branch]"; return 1; }
  local path=$(_wk-path "$branch")
  local root=$(_wk-repo-root)
  cd "$root"
  git worktree remove "$path" --force 2>/dev/null && echo "Removed: $branch ($path)"
}

function va () { source .venv/bin/activate ; }
function vn () {
  local python="${1:-3.13}"
  uv venv --python "$python" ".venv"
  echo "Created .venv (python $python)"
  source .venv/bin/activate
}
function vdd () {
  deactivate 2>/dev/null
  rm -rf .venv
  echo "Removed .venv"
}

# Tab title (directory name)
function set_terminal_title() { print -Pn '\e]0;%1~\a' }
precmd_functions+=(set_terminal_title)

# Key bindings
bindkey "^X\\x7f" backward-kill-line
bindkey "^X^_" redo

# Remove . from word characters so Option+Delete stops at periods
WORDCHARS=${WORDCHARS//.}

