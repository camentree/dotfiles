# npm global prefix (for packages managed outside Nix, e.g. claude-code)
export PATH="$HOME/.npm-global/bin:$PATH"

# Nix store paths (oh-my-zsh, etc.)
[[ -f ~/.nix-paths.sh ]] && source ~/.nix-paths.sh

# Oh-my-zsh
ZSH_THEME=""
plugins=(history)
ZSH_DISABLE_COMPFIX="true"
source $ZSH/oh-my-zsh.sh

# Starship prompt
eval "$(starship init zsh)"

# Aliases
alias pyc="rm **/*.pyc; rm -rf **/__pycache__"
alias cov-clean="rm .coverage.*"
alias git-open="open \`git config --get remote.origin.url\`"
alias vim="nvim"
alias vd="deactivate"
alias g="git"
alias gaa="git add --all"
alias gcm="git commit -m"
alias gco="git checkout"

# Functions
function loadenv () { set -o allexport; source "${1:-.}/.env"; set +o allexport ; }
function git-clean () {
  local default=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##')
  [ -z "$default" ] && { echo "Could not detect default branch (origin/HEAD not set)."; return 1; }
  git branch | grep -v "$default\|*" | xargs git branch -D
}
function ls-ports () { lsof -PiTCP -sTCP:LISTEN ; }

function nix-rebuild () { sudo $(which darwin-rebuild) switch --flake "$HOME/Projects/dotfiles#${1:?Usage: nix-rebuild <machine-name>}" ; }

function _wk-repo-root () { git rev-parse --path-format=absolute --git-common-dir 2>/dev/null | sed 's#/\.git$##'; }
function wk () {
  case "$1" in
    ls) shift; _wk-ls "$@"; return ;;
    rm) shift; _wk-rm "$@"; return ;;
  esac
  local mode=switch
  case "$1" in
    -b) mode=new-from-default; shift ;;
    -h) mode=new-from-here;   shift ;;
  esac
  local branch="$1"
  [ -z "$branch" ] && { echo "Usage: wk [-b|-h] <branch>"; return 1; }

  local repo_root=$(_wk-repo-root)
  [ -z "$repo_root" ] && { echo "Not in a git repo"; return 1; }
  local worktree_path="${repo_root:h}/.${repo_root:t}-worktrees/$branch"

  case "$mode" in
    switch)
      local existing=$(git worktree list --porcelain | awk -v b="refs/heads/$branch" '
        $1=="worktree" { p=$2 }
        $1=="branch" && $2==b { print p; exit }')
      if [ -n "$existing" ]; then cd "$existing"; return 0; fi
      git worktree add "$worktree_path" "$branch" || return 1
      ;;
    new-from-default)
      local default=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##')
      [ -z "$default" ] && { echo "Could not detect default branch (origin/HEAD not set). Use 'wk -h $branch' from the appropriate branch instead."; return 1; }
      git fetch origin "$default" --quiet 2>/dev/null
      git worktree add -b "$branch" --no-track "$worktree_path" "origin/$default" || return 1
      ;;
    new-from-here) git worktree add -b "$branch" "$worktree_path" || return 1 ;;
  esac

  local -A share_sources=()
  local share_file share_pattern share_source share_target
  for share_file in "$repo_root/.worktreeinclude" "$repo_root/.worktreeinclude.local"; do
    [ -f "$share_file" ] || continue
    while IFS= read -r share_pattern; do
      [[ -z "$share_pattern" || "$share_pattern" == \#* ]] && continue
      if [[ "$share_pattern" == !* ]]; then
        for share_source in "$repo_root"/${~share_pattern#!}(N); do
          unset "share_sources[$share_source]"
        done
      else
        for share_source in "$repo_root"/${~share_pattern}(N); do
          share_sources[$share_source]=1
        done
      fi
    done < "$share_file"
  done
  for share_source in "${(k)share_sources[@]}"; do
    share_target="$worktree_path/${share_source#$repo_root/}"
    mkdir -p "${share_target:h}"
    ln -sf "$share_source" "$share_target"
  done

  local rel="${PWD#$repo_root/}"
  cd "$worktree_path/$rel" 2>/dev/null || cd "$worktree_path"
}
function _wk-ls () {
  git worktree list --porcelain | awk '/^branch / { sub(/^refs\/heads\//, "", $2); print $2 }'
}
function _wk-rm () {
  local branch="${1:-$(git rev-parse --abbrev-ref HEAD 2>/dev/null)}"
  [ -z "$branch" ] && { echo "Usage: wk rm [branch]"; return 1; }
  local repo_root=$(_wk-repo-root)
  local worktree_path="${repo_root:h}/.${repo_root:t}-worktrees/$branch"
  [[ "$PWD" == "$worktree_path"* ]] && cd "$repo_root"
  local encoded_worktree="${worktree_path//\//-}"
  for proj_dir in "$HOME/.claude/projects/$encoded_worktree"(N) "$HOME/.claude/projects/${encoded_worktree}-"*(N); do
    for jsonl in "$proj_dir"/*.jsonl(N); do
      claude-move-session "${jsonl:t:r}" "$repo_root"
    done
    rmdir "$proj_dir" 2>/dev/null
  done
  git worktree remove "$worktree_path" --force 2>/dev/null
  git branch -D "$branch" 2>/dev/null
  echo "Removed: $branch"
}

function claude-move-session () {
  local session_id="$1"
  local target_path="${2:-$PWD}"
  [ -z "$session_id" ] && { echo "Usage: claude-move-session <session-id> [target-path]"; return 1; }
  local source_jsonl=$(find "$HOME/.claude/projects" -maxdepth 2 -name "${session_id}.jsonl" -print -quit 2>/dev/null)
  [ -z "$source_jsonl" ] && { echo "Session not found: $session_id"; return 1; }
  local source_dir="${source_jsonl:h}"
  [[ "$target_path" != /* ]] && target_path="$PWD/$target_path"
  target_path="${target_path%/}"
  local encoded="${target_path//\//-}"
  local target_dir="$HOME/.claude/projects/$encoded"
  mkdir -p "$target_dir"
  mv "$source_jsonl" "$target_dir/"
  [ -d "$source_dir/${session_id}" ] && mv "$source_dir/${session_id}" "$target_dir/"
  echo "Moved $session_id -> $encoded"
}

function va () { source .venv/bin/activate ; }
function vn () {
  local python="${1:-3.13}"
  uv venv --python "$python" ".venv"
  echo "Created .venv (python $python)"
  source .venv/bin/activate
}
function vdd () {
  deactivate 2>/dev/null
  rm -rf .venv
  echo "Removed .venv"
}

# Tab title (directory name)
function set_terminal_title() { print -Pn '\e]0;%1~\a' }
precmd_functions+=(set_terminal_title)

# Key bindings
bindkey "^X\\x7f" backward-kill-line
bindkey "^X^_" redo

# Remove . from word characters so Option+Delete stops at periods
WORDCHARS=${WORDCHARS//.}

