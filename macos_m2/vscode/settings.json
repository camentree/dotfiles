{
  // search
  "search.exclude": {
    "**/htmlcov": true,
    "docs/resources/**": true,
    "build/**": true,
  },
  // files
  "files.defaultLanguage": "python",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "files.exclude": {
    "**/__pycache__": true,
    "**/.cache": true,
    "**/.coverage": true,
    "**/.DS_Store": true,
    "**/.git": true,
    "**/.hg": true,
    "**/.ipynb_checkpoints": true,
    "**/.svn": true,
    "**/.tox": true,
    "**/.vscode": true,
    "**/*.egg-info": true,
    "**/*.pyc": true,
    "**/CVS": true,
    "**/.pytest_cache": true,
    "**/.coverage*": true,
    "~/Library/Caches/Python-Eggs": true,
  },
  "files.trimTrailingWhitespace": true,
  "files.watcherExclude": {
    "**/.bloop": true,
    "**/.metals": true,
    "**/target/**": true
},
  // explorer
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  "explorer.autoReveal": false,
  // editor
  "editor.detectIndentation": false,
  "editor.insertSpaces": true,
  "editor.wrappingIndent": "same",
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.minimap.enabled": false,
  "editor.cursorStyle": "block",
  "editor.fontFamily": "SFMono",
  "editor.fontSize": 13,
  "editor.formatOnSave": true,
  "editor.stickyScroll.enabled": false,
  "editor.foldingHighlight": false,
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "markup.italic.markdown",
        "settings": {
          "foreground": "#ed8796",
          "fontStyle": "italic",
        },
      },
      {
        "scope": "markup.bold.markdown",
        "settings": {
          "foreground": "#4e9a5e",
          "fontStyle": "bold",
        },
      },
    ],
  },
  // terminal
  "terminal.external.osxExec": "iTerm.app",
  "terminal.integrated.scrollback": 100000,
  "terminal.integrated.fontWeight": "100",
  "terminal.integrated.inheritEnv": false,
  "terminal.integrated.persistentSessionReviveProcess": "never",
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.allowChords": false,
  "terminal.integrated.confirmOnKill": "never",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.initialHint": false,
  // workbench
  "workbench.fontAliasing": "antialiased",
  "workbench.tree.indent": 4,
  "workbench.editor.closeOnFileDelete": true,
  "workbench.startupEditor": "none",
  "workbench.tips.enabled": false,
  "workbench.settings.editor": "json",
  "workbench.activityBar.location": "hidden",
  "workbench.layoutControl.enabled": false,
  "workbench.iconTheme": "catppuccin-macchiato",
  "workbench.colorTheme": "Catppuccin Macchiato",
  // keyboard
  "keyboard.touchbar.enabled": false,
  // window
  "window.autoDetectHighContrast": false,
  "window.nativeFullScreen": false,
  "window.restoreWindows": "none",
  "window.commandCenter": false,
  "window.zoomLevel": 1,
  // git
  "git.blame.editorDecoration.enabled": false,
  "git.blame.editorDecoration.disableHover": false,
  "git.blame.editorDecoration.template": "${authorName} (${authorDateAgo})",
  "git.blame.statusBarItem.enabled": false,
  "gitlens.codeLens.enabled": false,
  "gitlens.hovers.enabled": false,
  "gitlens.currentLine.enabled": false,
  "gitlens.currentLine.format": "${author}, ${agoOrDate}",
  "gitlens.blame.format": "${author|10} ${agoOrDate|14-}",
  "gitlens.blame.heatmap.enabled": true,
  // language: proto3
  "[proto3]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "bufbuild.vscode-buf",
  },
  // language: markdown
  "[markdown]": {
    "editor.tabSize": 2,
    "editor.wordWrap": "wordWrapColumn",
    "editor.wordWrapColumn": 90,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "markdown.editor.pasteUrlAsFormattedLink.enabled": "smart",
  "markdown.occurrencesHighlight.enabled": true,
  "markdown.preview.breaks": true,
  "markdown.suggest.paths.includeWorkspaceHeaderCompletions": "onSingleOrDoubleHash",
  // language: python
  "[python]": {
    "editor.formatOnPaste": false,
    "editor.wordWrap": "wordWrapColumn",
    "editor.wordWrapColumn": 90,
    "editor.rulers": [90],
    "editor.defaultFormatter": "ms-python.black-formatter",
  },
  "python.analysis.autoImportCompletions": false,
  "python.analysis.completeFunctionParens": false,
  "python.analysis.diagnosticMode": "workspace",
  "python.experiments.enabled": false,
  "python.testing.autoTestDiscoverOnSaveEnabled": false,
  "python.languageServer": "Pylance",
  "python.analysis.exclude": ["*.ipynb"],
  "python.analysis.diagnosticSeverityOverrides": {
    "reportMissingImports": "none",
  },
  // language: yaml
  "[yaml]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.wordWrapColumn": 100,
  },
  // language: scala

  "[scala]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "scalameta.metals",
    "editor.detectIndentation": false,
    "editor.tabSize": 2,
    "editor.wordWrapColumn": 100,
  },
  "metals.javaHome": "/Users/camen/.local/share/mise/installs/java/temurin-17.0.16+8",
  "metals.serverProperties": ["-Xmx8192m", "-Xss4m", "-XX:+UseG1GC"],
  "metals.enableIndentOnPaste": true,
  "metals.shutdownBloopOnEditorClose": true,
  "metals.testUserInterface": "Code Lenses",
  "metals.enableSemanticHighlighting": false,
  "metals.superMethodLensesEnabled": false,
  "metals.inlayHints.inferredTypes.enable": false,
  "metals.inlayHints.implicitArguments.enable": false,
  "metals.inlayHints.implicitConversions.enable": false,
  "metals.inlayHints.typeParameters.enable": false,
  "metals.inlayHints.hintsInPatternMatch.enable": false,
  "metals.bloopSbtAlreadyInstalled": true,
  "[routes]": {
    "editor.defaultFormatter": "august.august-play-routes",
    "editor.formatOnSave": false,
  },
  "augustPlayRoutes.formatting.methodColumnWidth": 8,
  "augustPlayRoutes.formatting.pathColumnWidth": 80,
  "augustPlayRoutes.formatting.paddingSpaces": 3,
  // language: json
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "json.schemaDownload.trustedDomains": {
    "https://schemastore.azurewebsites.net/": true,
    "https://raw.githubusercontent.com/": true,
    "https://www.schemastore.org/": true,
    "https://json.schemastore.org/": true,
    "https://json-schema.org/": true,
    "https://esm.sh": true,
  },
  // language: typescript
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
  },
  // extensions: claude code
  "claudeCode.useTerminal": true,
  // misc
  "security.workspace.trust.untrustedFiles": "open",
  "security.promptForLocalFileProtocolHandling": false,
  "breadcrumbs.enabled": false,
  "update.showReleaseNotes": false,
  "accessibility.verbosity.sourceControl": false,
  "gitlens.showWhatsNewAfterUpgrades": false,
  "gitlens.plusFeatures.enabled": false,
  "gitlens.statusBar.enabled": false,
  "gitlens.statusBar.pullRequests.enabled": false,
  "workbench.settings.showAISearchToggle": false,
  "chat.disableAIFeatures": true,
  "gitlens.ai.enabled": false,
  "python.analysis.aiHoverSummaries": false,
  "editor.lightbulb.enabled": "off",
  "chat.extensionUnification.enabled": false,
  "workbench.editor.editorActionsLocation": "hidden",
  "editor.snippets.codeActions.enabled": false,
  "editor.codeActionWidget.includeNearbyQuickFixes": false,
}
