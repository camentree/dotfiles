{
  "env": {
    "DIRHELPER_USER_DIR_SUFFIX": ""
  },
  "enabledPlugins": {
    "security-guidance@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(git branch *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git stash *)",
      "Bash(git status *)",
      "Bash(cat *)",
      "Bash(sysctl *)",
      "Bash(lsof *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(sbt *)",
      "Bash(which *)",
      "Bash(pwd)",
      "Bash(echo *)",
      "Bash(env *)",
      "Bash(defaults *)",
      "Bash(mdfind *)",
      "Bash(npm run compile *)",
      "Bash(curl -X GET *)",
      "Bash(pbcopy)",
      "WebSearch",
      "WebFetch",
      "Read",
      "Bash(mise where:*)",
      "Bash(npx difit *)",
      "Skill(keybindings-help)",
      "mcp__linear__list_issues",
      "mcp__linear__get_issue",
      "mcp__linear__list_comments",
      "mcp__notion__notion-fetch",
      "mcp__notion__notion-search",
      "mcp__chrome-devtools__list_pages"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME*)",
      "Bash(sudo rm *)",
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(chmod -R 777 *)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": ["~/", "/tmp"]
  },
  "promptSuggestionEnabled": false,
  "autoDreamEnabled": true,
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/format-on-edit.sh"
          }
        ]
      }
    ]
  }
}
